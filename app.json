{
  "expo": {
    "name": "Incubator Monitor",
    "slug": "incubator-monitor",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#09090b",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },

    "assetBundlePatterns": ["**/*"],

    "android": {
      "package": "com.agash.incubator",
      "versionCode": 2,
      "permissions": ["INTERNET", "VIBRATE", "WAKE_LOCK"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#09090b"
      }
    },

    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981"
        }
      ],
      "expo-av"
    ],

    "extra": {
      "eas": {
        "projectId": "eaff9dde-2982-49a6-942a-93a387da5cbd"
      }
    },

    "owner": "tndeals"
  }
}
